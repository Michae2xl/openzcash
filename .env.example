# Copy to .env.local and fill in. NEVER put real secrets in this file.
# Everything here is names + placeholders only; .env.local is gitignored.

# ── Core (required to run) ────────────────────────────────────────────────
# Postgres connection string.
DATABASE_URL=postgres://USER@localhost:5432/openzcash

# Which ZCG public spreadsheet to mirror (Google Sheets file id).
ZCG_SHEET_ID=

# ── Admin (the write side; the public read side needs none of this) ───────
# Password for the /login admin session.
ADMIN_PASSWORD=
# HMAC key for signing session cookies. Generate: openssl rand -hex 32
SESSION_SECRET=
# Bearer token guarding GET /api/cron/refresh. Generate: openssl rand -hex 32
CRON_SECRET=
# libsodium sealed-box keypair for treasury onboarding (base64).
ONBOARDING_PUBLIC_KEY=
ONBOARDING_SECRET_KEY=

# ── On-chain data (node-less: public lightwalletd + scanner) ──────────────
# lightwalletd endpoint. Port :443 is treated as TLS. e.g. zec.rocks:443
LWD_URL=zec.rocks:443
# ppf-scanner service for watch-only UFVK validation/derivation.
SCANNER_URL=
SCANNER_SECRET=

# ── Optional: self-hosted Zcash node (degrades gracefully if unset) ───────
# "mock" uses the built-in dataset; "real" uses the node RPC below.
ZCASH_GATEWAY=mock
# Zebra full node RPC (must listen on 0.0.0.0 for LAN access).
ZEBRA_RPC_URL=http://NODE_HOST:8232
ZEBRA_RPC_USER=
ZEBRA_RPC_PASSWORD=
# zallet wallet RPC (its own port, separate from Zebra).
ZALLET_RPC_URL=http://NODE_HOST:PORT
ZALLET_RPC_USER=
ZALLET_RPC_PASSWORD=
ZALLET_ACCOUNT_UUID=
# zkool2 (zkool-graphql) — watch-only UFVK history + memos via GraphQL.
ZKOOL_GRAPHQL_URL=http://NODE_HOST:PORT/graphql
ZKOOL_JWT_TOKEN=
