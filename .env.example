# Copie para .env.local e preencha. NÃO coloque segredos reais aqui.

DATABASE_URL=postgres://USER@localhost:5432/zec_backoffice

# "mock" usa o dataset embutido; "real" usa o RPC do node (Zebra + zallet)
ZCASH_GATEWAY=mock

# Node Zcash (Zebra) — RPC precisa escutar em 0.0.0.0 para acesso pela LAN
ZEBRA_RPC_URL=http://NODE_HOST:8232
ZEBRA_RPC_USER=
ZEBRA_RPC_PASSWORD=

# Carteira zallet — porta própria (diferente do Zebra)
ZALLET_RPC_URL=http://NODE_HOST:PORT
ZALLET_RPC_USER=
ZALLET_RPC_PASSWORD=

# zkool2 (zkool-graphql) — stack recomendada (UFVK watch-only + FROST)
ZKOOL_GRAPHQL_URL=http://NODE_HOST:PORT/graphql
ZKOOL_JWT_TOKEN=
